{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/audio/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/backgrounds/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/profile-images/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
