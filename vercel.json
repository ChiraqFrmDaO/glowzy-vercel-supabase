{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "server/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/audio/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/backgrounds/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/profile-images/(.*)",
      "destination": "/server/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
